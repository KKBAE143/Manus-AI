{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node -e \"const fs=require('fs');if(!fs.existsSync('.env'))fs.copyFileSync('.env.example','.env');\"",
    "dev": "vite --port=5000 --host=0.0.0.0",
    "dev:backend": "cd backend && set PYTHONPATH=.. && venv\\Scripts\\python.exe -m uvicorn app.main:app --host localhost --port 8000 --reload --reload-dir app",
    "dev:all": "concurrently -n VITE,API -c cyan,magenta \"npm run dev\" \"npm run dev:backend\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs');const p='dist';if(fs.existsSync(p))fs.rmSync(p,{recursive:true});\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "better-sqlite3": "^12.8.0",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "file-saver": "^2.0.5",
    "firebase": "^12.11.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.19.15",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.1"
  }
}
