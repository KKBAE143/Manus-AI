# =============================================================================
# Production environment for the Oracle VM. Copy this file to `.env` on the VM
# and fill in your real values. NEVER commit the real .env.
# =============================================================================

# Public domain Caddy will issue SSL for. Required.
# e.g. exam.example.com  (no protocol, no trailing slash)
DOMAIN=

# Comma-separated list of origins the API will accept. Set to your domain.
# e.g. https://exam.example.com
CORS_ALLOW_ORIGINS=

# Optional: only set this if you actually use Gemini features (manuscript
# pipeline). The Quiz Cleaner does not need it.
GEMINI_API_KEY=
