# Copy this file to .env and fill in your values.
# The frontend (Vite) reads VITE_* variables; the backend reads the rest.

# --- AI (Required for AI transformation pass) ---
# Get a free key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: extra Gemini keys for round-robin rotation (higher throughput)
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=

# Optional: Groq keys as a fallback AI provider
# GROQ_API_KEY_1=
# GROQ_API_KEY_2=

# --- Database (optional) ---
# Leave blank to use local SQLite — recommended for local development.
# Set to a PostgreSQL URL for production: postgresql://user:pass@host/db
# DATABASE_URL=

# --- Auth ---
# Set to true to skip Firebase login (recommended for local dev).
VITE_DISABLE_AUTH=true
